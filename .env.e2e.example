# E2E Test Environment Variables
# Copy to .env.e2e and fill in:
#   cp .env.e2e.example .env.e2e

# Supabase project URL (same as EXPO_PUBLIC_SUPABASE_URL, auto-read from .env if omitted)
# SUPABASE_URL=https://xxx.supabase.co

# Secret key (Settings → API Keys → Secret key, starts with sb_secret_)
SUPABASE_SECRET_KEY=sb_secret_...

# Publishable key (same as EXPO_PUBLIC_SUPABASE_KEY, auto-read from .env if omitted)
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
